{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maldives-genealogy.local/schemas/dataset.schema.json",
  "title": "Genealogy Dataset",
  "type": "object",
  "required": ["mode", "people", "edges"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": ["canonical", "research"]
    },
    "people": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^P[0-9]+$" },
          "nm": { "type": "string" },
          "dy": { "type": "string" },
          "g": { "type": "string" },
          "source_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["t", "s", "d", "c"],
        "properties": {
          "t": {
            "type": "string",
            "enum": ["parent", "sibling", "spouse", "kin"]
          },
          "s": { "type": "string", "pattern": "^P[0-9]+$" },
          "d": { "type": "string", "pattern": "^P[0-9]+$" },
          "l": { "type": "string" },
          "c": {
            "type": "string",
            "enum": ["c", "i", "u"]
          },
          "claim_type": { "type": "string" },
          "confidence_grade": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
